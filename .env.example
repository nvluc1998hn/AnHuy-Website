# Local dev server
PORT=5174
HOST=0.0.0.0

# Used by Netlify Functions to validate admin login tokens before R2 upload/delete.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Cloudflare R2 upload config. Do not expose these values in frontend code.
CLOUDFLARE_ACCOUNT_ID=
R2_BUCKET_NAME=anhuy-image
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Public CDN/custom domain used to render uploaded images.
# Example: https://cdn.anhuy.com
R2_PUBLIC_BASE_URL=
